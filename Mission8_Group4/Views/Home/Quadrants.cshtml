@using System.Linq

@model List<Mission8_Group4.Models.Task>

<div class="container mt-4">
    <div class="matrix-container shadow">
        
        <div class="row border-bottom border-dark">
            <div class="col-12 text-center py-3">
                <h2 class="mb-0 fw-bold">STEPHEN COVEY'S TIME MANAGEMENT MATRIX</h2>
            </div>
        </div>

        <div class="row border-bottom border-dark text-center fw-bold">
            <div class="col-2 border-end border-dark"></div> <div class="col-5 border-end border-dark py-2">URGENT</div>
            <div class="col-5 py-2">NOT URGENT</div>
        </div>

        <div class="row border-bottom border-dark">
            <div class="col-2 d-flex align-items-center justify-content-center border-end border-dark p-0">
                <h5 class="vertical-text m-0">IMPORTANT</h5>
            </div>
            <div class="col-5 border-end border-dark quadrant">
                <h6 class="fw-bold">Quadrant 1</h6>
                <ul class="list-unstyled">
                    @foreach (var task in Model.Where(t => t.quadrant == 1))
                    {
                        <li class="quadrant-task p-2 border-bottom border-light">
                            <span class="task-name">@task.name</span>
                            <div class="task-actions">
                                <a class="btn btn-task-edit btn-sm" asp-controller="Home" asp-action="Edit" asp-route-id="@task.id">Edit</a>
                                <form asp-controller="Home" asp-action="Delete" asp-route-id="@task.id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-task-delete btn-sm">Delete</button>
                                </form>
                            </div>
                        </li>
                    }
                </ul>
            </div>
            <div class="col-5 quadrant">
                <h6 class="fw-bold">Quadrant 2</h6>
                <ul class="list-unstyled">
                    @foreach (var task in Model.Where(t => t.quadrant == 2))
                    {
                        <li class="quadrant-task p-2 border-bottom border-light">
                            <span class="task-name">@task.name</span>
                            <div class="task-actions">
                                <a class="btn btn-task-edit btn-sm" asp-controller="Home" asp-action="Edit" asp-route-id="@task.id">Edit</a>
                                <form asp-controller="Home" asp-action="Delete" asp-route-id="@task.id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-task-delete btn-sm">Delete</button>
                                </form>
                            </div>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <div class="row">
            <div class="col-2 d-flex align-items-center justify-content-center border-end border-dark p-0">
                <h5 class="vertical-text m-0">NOT IMPORTANT</h5>
            </div>
            <div class="col-5 border-end border-dark quadrant">
                <h6 class="fw-bold">Quadrant 3</h6>
                <ul class="list-unstyled">
                    @foreach (var task in Model.Where(t => t.quadrant == 3))
                    {
                        <li class="quadrant-task p-2 border-bottom border-light">
                            <span class="task-name">@task.name</span>
                            <div class="task-actions">
                                <a class="btn btn-task-edit btn-sm" asp-controller="Home" asp-action="Edit" asp-route-id="@task.id">Edit</a>
                                <form asp-controller="Home" asp-action="Delete" asp-route-id="@task.id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-task-delete btn-sm">Delete</button>
                                </form>
                            </div>
                        </li>

                    }
                </ul>
            </div>
            <div class="col-5 quadrant">
                <h6 class="fw-bold">Quadrant 4</h6>
                <ul class="list-unstyled">
                    @foreach (var task in Model.Where(t => t.quadrant == 4))
                    {
                        <li class="quadrant-task p-2 border-bottom border-light">
                            <span class="task-name">@task.name</span>
                            <div class="task-actions">
                                <a class="btn btn-task-edit btn-sm" asp-controller="Home" asp-action="Edit" asp-route-id="@task.id">Edit</a>
                                <form asp-controller="Home" asp-action="Delete" asp-route-id="@task.id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-task-delete btn-sm">Delete</button>
                                </form>
                            </div>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>
